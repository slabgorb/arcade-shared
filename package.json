{
  "name": "@arcade/shared",
  "version": "0.17.0",
  "description": "Shared library for the slabgorb browser vector-arcade games (ADR-0001). Consumed as a version-pinned git-URL dependency.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slabgorb/arcade-shared.git"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./math3d": {
      "types": "./dist/math3d.d.ts",
      "import": "./dist/math3d.js"
    },
    "./rng": {
      "types": "./dist/rng.d.ts",
      "import": "./dist/rng.js"
    },
    "./highscore": {
      "types": "./dist/highscore.d.ts",
      "import": "./dist/highscore.js"
    },
    "./loop": {
      "types": "./dist/loop.d.ts",
      "import": "./dist/loop.js"
    },
    "./font": {
      "types": "./dist/font.d.ts",
      "import": "./dist/font.js"
    },
    "./name-entry": {
      "types": "./dist/name-entry.d.ts",
      "import": "./dist/name-entry.js"
    },
    "./pause": {
      "types": "./dist/pause.d.ts",
      "import": "./dist/pause.js"
    },
    "./esc-overlay": {
      "types": "./dist/esc-overlay.d.ts",
      "import": "./dist/esc-overlay.js"
    },
    "./glow": {
      "types": "./dist/glow.d.ts",
      "import": "./dist/glow.js"
    },
    "./view": {
      "types": "./dist/view.d.ts",
      "import": "./dist/view.js"
    },
    "./audio": {
      "types": "./dist/audio.d.ts",
      "import": "./dist/audio.js"
    },
    "./synth": {
      "types": "./dist/synth.d.ts",
      "import": "./dist/synth.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepare": "tsc -p tsconfig.build.json",
    "pretest": "tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
