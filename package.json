{
  "name": "@arcade/shared",
  "version": "0.3.0",
  "description": "Shared library for the slabgorb browser vector-arcade games (ADR-0001). Consumed as a version-pinned git-URL dependency.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slabgorb/arcade-shared.git"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./math3d": {
      "types": "./dist/math3d.d.ts",
      "import": "./dist/math3d.js"
    },
    "./rng": {
      "types": "./dist/rng.d.ts",
      "import": "./dist/rng.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepare": "tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
